generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model bookings {
  id             BigInt   @id @default(autoincrement())
  barber_id      Int
  barber_name    String?
  customer_name  String
  date           DateTime @db.Date
  time           DateTime @db.Time(6)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  is_silent      Boolean  @default(false)
  requirements   String?
  customer_token String?

  @@unique([barber_id, date, time], map: "bookings_unique_slot")
  @@index([customer_token], map: "idx_bookings_customer_token")
}

model services {
  id               Int    @id @default(autoincrement())
  shop_id          Int?
  name             String
  price_pence      Int
  duration_minutes Int
  shops            shops? @relation(fields: [shop_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model shops {
  id               Int        @id @default(autoincrement())
  name             String
  created_at       DateTime?  @default(now()) @db.Timestamptz(6)
  supports_silent  Boolean    @default(false)
  address          String?
  postcode         String?
  lat              Float?
  lng              Float?
  base_price_pence Int?
  image_url        String?
  cover_url        String?
  styles           String[]   @default([])
  is_partner       Boolean?   @default(false)
  external_url     String?
  services         services[]
}

enum silence_mode {
  silent
  minimal
  normal
}
